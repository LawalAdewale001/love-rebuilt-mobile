{
  "expo": {
    "name": "LoveRebuilt",
    "slug": "love-rebuilt-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icons/ios/AppIcon.appiconset/ItunesArtwork@2x.png",
    "scheme": "loverebuitmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/app-icons/ios/AppIcon.appiconset/ItunesArtwork@2x.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.loverebuilt",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "LoveRebuilt needs access to your camera for video calls.",
        "NSMicrophoneUsageDescription": "LoveRebuilt needs access to your microphone for audio and video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#e86a7a",
        "foregroundImage": "./assets/app-icons/android/mipmap-xxxhdpi/ic_launcher_foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.loverebuilt",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icons/ios/AppIcon.appiconset/ItunesArtwork@2x.png",
          "color": "#E86673",
          "androidMode": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-screen/splash.png",
          "imageWidth": 350,
          "resizeMode": "contain",
          "backgroundColor": "#E86A7A",
          "dark": {
            "backgroundColor": "#E86A7A"
          }
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "light": {
              "colorAccent": "#E86A7A",
              "colorPrimary": "#E86A7A",
              "colorControlActivated": "#E86A7A",
              "headerBackground": "#E86A7A",
              "headerTextColor": "#FFFFFF",
              "textColor": "#1A1A1A",
              "textColorPrimary": "#1A1A1A"
            },
            "dark": {
              "colorAccent": "#E86A7A",
              "colorPrimary": "#E86A7A",
              "colorControlActivated": "#E86A7A",
              "headerBackground": "#E86A7A",
              "headerTextColor": "#FFFFFF",
              "textColor": "#FFFFFF",
              "textColorPrimary": "#FFFFFF"
            }
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you set your profile picture.",
          "cameraPermission": "The app needs access to your camera to let you take a profile picture.",
          "colors": {
            "cropToolbarColor": "#FFFFFF",
            "cropToolbarIconColor": "#1A1A1A",
            "cropToolbarActionTextColor": "#E86A7A",
            "cropBackButtonIconColor": "#1A1A1A",
            "cropBackgroundColor": "#FFFFFF"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "enableProguardInReleaseBuilds": true,
            "allowBackup": false,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5f29157d-8fb5-49c6-ad06-94df003ed1a7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
